# ─────────────────────────────────────────────────────────────────────────────
# cha-bot-starter-kit — 환경변수 템플릿
# ─────────────────────────────────────────────────────────────────────────────
# 사용법
#   1) 이 파일을 ".env" 라는 이름으로 복사 (로컬 개발용)
#        cp .env.example .env
#   2) 각 항목 옆 안내대로 본인 값을 채워넣기
#   3) Vercel 배포 시에는 같은 변수들을 Vercel 대시보드의
#        Project Settings → Environment Variables 에 등록
#
# 보안
#   - .env 파일은 절대 git 에 커밋하지 마세요 (.gitignore 에 이미 등록됨)
#   - VITE_* 로 시작하는 변수는 브라우저에 노출됩니다
#     → 진짜 비밀 키(서버 전용)는 VITE_ 접두사 없이 사용하세요
# ─────────────────────────────────────────────────────────────────────────────


# ─── 프론트엔드 (브라우저 노출 OK, 도메인 제한으로 보호) ───────────────────────

# 카카오 JavaScript SDK 키
#   발급 방법:
#     https://developers.kakao.com/ → 로그인 → 내 애플리케이션 → 애플리케이션 추가
#     → 앱 생성 후 "앱 키" 메뉴 → "JavaScript 키" 복사
#   주의:
#     카카오 디벨로퍼 콘솔의 "플랫폼 → Web" 에 본인 Vercel 도메인 등록 필수
#     (예: https://my-bot.vercel.app)
VITE_KAKAO_JS_KEY=your_kakao_javascript_key_here


# ─── 서버 사이드 시크릿 (브라우저 노출 금지) ─────────────────────────────────
# 아래 변수들은 Vercel Serverless Function (api/*.js) 에서만 사용됩니다.

# 온프레미스 서버 (학교 서버 + 미들턴 서버 통합 호칭) 접근 정보
# - LLM(Ollama), 임베딩, RAG retrieval, 데이터베이스가 모두 여기에 있습니다
ONPREMISE_BASE_URL=https://your-onpremise-server.example.com
ONPREMISE_API_KEY=your_api_key_here

# OpenAI (선택 — STT/TTS fallback 으로 사용)
OPENAI_API_KEY=sk-...
